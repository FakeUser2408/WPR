# Frontend (Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Optional: client-side Gemini (site photo UI flows)
VITE_GEMINI_API_KEY=

# Supabase Edge Functions — set via: supabase secrets set NAME=value
# OpenRouter (replaces CLAUDE_API_KEY for WPR text analysis)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Default: anthropic/claude-haiku-4.5 (matches legacy audit depth)
# For DeepSeek: deepseek/deepseek-v3.2 (avoid deepseek-chat — too shallow for full WPR audits)
OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# Other edge function secrets (unchanged)
DB_URL=
SERVICE_ROLE_KEY=
GEMINI_API_KEY=
RESEND_API_KEY=
