# =============================================================================
# FRONTEND (Vite)
# =============================================================================

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Optional: client-side Gemini (site photo UI flows)
VITE_GEMINI_API_KEY=

# Legacy / unused by app currently (kept for reference)
# VITE_GROQ_API_KEY=
# VITE_CLAUDE_API_KEY=

# Optional: override OpenRouter model from the browser during local dev
# VITE_OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free

# =============================================================================
# SUPABASE EDGE FUNCTIONS (local serve + production secrets)
# =============================================================================

DB_URL=https://your-project.supabase.co
SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-publishable-or-anon-key

OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Default primary model. Fallbacks are automatic in code — no secret needed.
OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
# Optional: override the built-in fallback list (comma-separated)
# OPENROUTER_MODEL_FALLBACKS=openai/gpt-oss-120b:free,meta-llama/llama-3.3-70b-instruct:free,openrouter/free

GEMINI_API_KEY=
RESEND_API_KEY=
EMAIL_FROM=WPR Audit <noreply@wpraudit.com>

# =============================================================================
# KEEP-ALIVE (optional — prevents Supabase free tier from pausing after ~7 days idle)
# Set GitHub secrets SUPABASE_URL + SUPABASE_ANON_KEY for .github/workflows/supabase-keep-alive.yml
# Then deploy: supabase functions deploy keep-alive
# =============================================================================
